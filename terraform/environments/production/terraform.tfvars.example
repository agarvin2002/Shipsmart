# ShipSmart AI API - Production Environment Configuration
#
# CRITICAL SECURITY WARNING:
# - Copy this file to terraform.tfvars and fill in actual values
# - DO NOT commit terraform.tfvars to git - it contains sensitive information
# - Add terraform.tfvars to .gitignore
# - Use DIFFERENT secrets than staging (never reuse passwords/keys)
# - Use AWS Secrets Manager or environment variables for CI/CD

aws_region = "us-east-1"
image_tag  = "latest"

# Sensitive values - CHANGE THESE BEFORE DEPLOYMENT
# IMPORTANT: Use DIFFERENT values than staging environment
# Use environment variables instead: export TF_VAR_db_password="your-password"
#
# db_username     = "shipsmart_prod_admin"
# db_password     = "CHANGE_ME_DIFFERENT_STRONG_PASSWORD_48_CHARS_MIN"
# jwt_secret      = "CHANGE_ME_DIFFERENT_JWT_SECRET_48_CHARS_OR_MORE"
# encryption_key  = "abcdefghijklmnopqrstuvwxyz123456"  # Exactly 32 chars, different from staging
#
# certificate_arn   = "arn:aws:acm:us-east-1:123456789012:certificate/yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy"
# route53_zone_id   = "Z1234567890ABC"

# Instructions:
# 1. Copy this file: cp terraform.tfvars.example terraform.tfvars
# 2. Generate STRONG, UNIQUE passwords (different from staging):
#    - db_password: openssl rand -base64 48
#    - jwt_secret: openssl rand -base64 64
#    - encryption_key: openssl rand -hex 16 (must be exactly 32 characters)
# 3. Get certificate ARN from AWS ACM (create certificate for api.shipsmart.com)
# 4. Get Route53 zone ID from AWS Route53
# 5. Uncomment and fill in all values
# 6. Verify terraform.tfvars is in .gitignore
# 7. Store secrets in AWS Secrets Manager for Jenkins CI/CD

# Production Deployment Checklist:
# [ ] Test on staging first
# [ ] Review security group rules
# [ ] Enable deletion protection on critical resources
# [ ] Set up CloudWatch alarms
# [ ] Configure backup strategy
# [ ] Document rollback procedure
# [ ] Enable AWS CloudTrail for auditing
# [ ] Review IAM policies and permissions
