# ShipSmart AI API - Staging Environment Configuration
#
# IMPORTANT: Copy this file to terraform.tfvars and fill in actual values
# DO NOT commit terraform.tfvars to git - it contains sensitive information
# Add terraform.tfvars to .gitignore

aws_region = "us-east-1"
image_tag  = "staging"

# Sensitive values - CHANGE THESE BEFORE DEPLOYMENT
# Use environment variables instead: export TF_VAR_db_password="your-password"
#
# db_username     = "shipsmart_admin"
# db_password     = "CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN"
# jwt_secret      = "CHANGE_ME_JWT_SECRET_32_CHARS_OR_MORE_RANDOM_STRING"
# encryption_key  = "12345678901234567890123456789012"  # Exactly 32 chars
#
# certificate_arn   = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# route53_zone_id   = "Z1234567890ABC"

# Instructions:
# 1. Copy this file: cp terraform.tfvars.example terraform.tfvars
# 2. Generate strong passwords:
#    - db_password: openssl rand -base64 32
#    - jwt_secret: openssl rand -base64 48
#    - encryption_key: openssl rand -hex 16 (must be exactly 32 characters)
# 3. Get certificate ARN from AWS ACM (create certificate for staging.shipsmart.com)
# 4. Get Route53 zone ID from AWS Route53
# 5. Uncomment and fill in all values
# 6. Verify terraform.tfvars is in .gitignore
