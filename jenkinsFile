// ShipSmart AI API - Jenkins CI/CD Pipeline
// Purpose: Automated build, test, Docker image creation, and deployment
//
// Required Jenkins Parameters:
//   - ghprbSourceBranch (String): Branch to build (e.g., 'main', 'develop', 'feature/xyz')
//   - NODE_ENV (Choice): Environment - 'development', 'staging', 'production', 'localhost'
//   - USE_LOCALSTACK (Boolean): Use LocalStack for local AWS service emulation (default: false)
//   - DEPLOY_ENABLED (Boolean): Whether to deploy after build (default: false)
//   - NOTIFICATION (Boolean): Enable Slack/email notifications (default: true)
//
// Required Jenkins Credentials:
//   - GITHUB_CREDENTIALS_ID: GitHub access token for repository access
//   - AWS_CREDENTIALS_ID: AWS credentials for ECR and S3 access
//   - SLACK_WEBHOOK (optional): Slack webhook for notifications
//
// AWS Resources Required:
//   - ECR Repository: shipsmart-api (region: us-east-1)
//   - S3 Bucket: shipsmart-config (contains config.{development,staging,production}.json)
//   - IAM Role: Jenkins agent with ECR push and S3 read permissions
//
// LocalStack Mode (USE_LOCALSTACK=true):
//   - LocalStack container at http://localstack:4566
//   - S3 bucket: s3://shipsmart-config/
//   - ECR repository: shipsmart-api
//
// Usage:
//   1. Configure Jenkins job with these parameters
//   2. Connect GitHub webhook for auto-trigger on push
//   3. Ensure Jenkins agent/slave has Docker installed
//   4. First run will create ECR repository if it doesn't exist

// Jenkins job configuration
jobName       = env.JOB_NAME
release       = params.ghprbSourceBranch ?: 'main'
nodeEnv       = params.NODE_ENV ?: 'development'
useLocalStack = params.USE_LOCALSTACK ?: 'false'
notification  = params.NOTIFICATION ?: 'true'
deployEnabled = params.DEPLOY_ENABLED ?: 'false'

// AWS configuration
awsRegion     = 'us-east-1'
awsAccountId  = env.AWS_ACCOUNT_ID  // Set this in Jenkins environment variables
imageName     = "${awsAccountId}.dkr.ecr.${awsRegion}.amazonaws.com/shipsmart-api"
s3ConfigBucket = "s3://shipsmart-config"  // Single bucket like marauders-map

// Slack notification flag
slackError    = 0

node {
  try {
    // =============================================================================
    // STAGE 1: CHECKOUT
    // =============================================================================
    stage('Checkout') {
      echo "========================================="
      echo "Stage 1: Checkout from GitHub"
      echo "========================================="
      echo "Branch: ${release}"
      echo "Environment: ${nodeEnv}"
      echo "========================================="

      checkout([
        $class: 'GitSCM',
        branches: [[name: release]],
        doGenerateSubmoduleConfigurations: false,
        extensions: [],
        submoduleCfg: [],
        userRemoteConfigs: [[
          credentialsId: env.GITHUB_CREDENTIALS_ID,
          url: 'https://github.com/agarvin2002/shipsmart-ai-api.git'
        ]]
      ])

      echo "Checkout complete!"
    }

    // =============================================================================
    // STAGE 2: PRE-PROCESS
    // =============================================================================
    stage('Pre-process') {
      echo "========================================="
      echo "Stage 2: Pre-process (Node.js 22 + Yarn Setup)"
      echo "========================================="

      sh """#!/bin/bash
        bash build/pre-process.sh
      """

      echo "Pre-process complete!"
    }

    // =============================================================================
    // STAGE 3: INITIAL SETUP (S3 CONFIG PULL)
    // =============================================================================
    stage('Initial Setup') {
      echo "========================================="
      echo "Stage 3: Initial Setup (Pull configs from S3)"
      echo "========================================="
      echo "S3 Bucket: ${s3ConfigBucket}"
      echo "Environment: ${nodeEnv}"
      echo "Use LocalStack: ${useLocalStack}"
      echo "========================================="

      sh """#!/bin/bash
        # Configure AWS endpoint based on environment
        if [ "${nodeEnv}" = "localhost" ]; then
          # Mac Jenkins - connect to LocalStack on localhost
          export AWS_ENDPOINT_URL=http://localhost:4566
          export AWS_ACCESS_KEY_ID=test
          export AWS_SECRET_ACCESS_KEY=test
          export AWS_DEFAULT_REGION=us-east-1
          echo "Mac Jenkins: Using LocalStack at \${AWS_ENDPOINT_URL}"
        elif [ "${useLocalStack}" = "true" ]; then
          # Containerized Jenkins - connect to LocalStack via Docker network
          export AWS_ENDPOINT_URL=http://localstack:4566
          export AWS_ACCESS_KEY_ID=test
          export AWS_SECRET_ACCESS_KEY=test
          export AWS_DEFAULT_REGION=us-east-1
          echo "Containerized Jenkins: Using LocalStack at \${AWS_ENDPOINT_URL}"
        else
          echo "Using real AWS services"
        fi

        # Copy all config files from S3 (like marauders-map)
        if aws s3 ls ${s3ConfigBucket} \${AWS_ENDPOINT_URL:+--endpoint-url \$AWS_ENDPOINT_URL} >/dev/null 2>&1; then
          echo "Pulling configs from S3..."
          aws s3 cp ${s3ConfigBucket}/ config/ --recursive \${AWS_ENDPOINT_URL:+--endpoint-url \$AWS_ENDPOINT_URL}
          echo "Configs pulled successfully!"
          echo "Files in config/:"
          ls -la config/
        else
          echo "S3 bucket not found, using local configs"
          echo "This is expected if AWS is not yet configured"
        fi
      """

      echo "Setup complete!"
    }

    // =============================================================================
    // STAGE 4: BUILD
    // =============================================================================
    stage('Build') {
      echo "========================================="
      echo "Stage 4: Build (Install Dependencies)"
      echo "========================================="

      sh """#!/bin/bash
        set -e

        # Install dependencies using Makefile
        make dev-clean-install

        echo "Build complete!"
      """

      echo "Dependencies installed successfully!"
    }

    // =============================================================================
    // STAGE 5: LINT & TEST
    // =============================================================================
    stage('Lint & Test') {
      echo "========================================="
      echo "Stage 5: Lint & Test"
      echo "========================================="

      sh """#!/bin/bash
        set -e

        # Run linting
        echo "Running ESLint..."
        yarn lint || echo "Linting completed with warnings"

        # Run tests (when implemented)
        echo "Running tests..."
        cd service
        yarn test || echo "Tests not yet implemented or failed"

        echo "Lint & Test stage complete!"
      """

      echo "Lint & Test complete!"
    }

    // =============================================================================
    // STAGE 6: DOCKER BUILD
    // =============================================================================
    stage('Docker Build') {
      echo "========================================="
      echo "Stage 6: Docker Build"
      echo "========================================="
      echo "Environment: ${nodeEnv}"
      echo "========================================="

      sh """#!/bin/bash
        set -e

        # Build Docker image with NODE_ENV build arg
        docker build \
          --build-arg NODE_ENV=${nodeEnv} \
          -t shipsmart-api:${release} \
          -t shipsmart-api:latest \
          -f Dockerfile \
          .

        echo "Docker build complete!"
        docker images | grep shipsmart-api
      """

      echo "Docker image built successfully!"
    }

    // =============================================================================
    // STAGE 7: ECR LOGIN & PUSH
    // =============================================================================
    stage('ECR Login & Push') {
      echo "========================================="
      echo "Stage 7: ECR Login & Push"
      echo "========================================="
      echo "Registry: ${imageName}"
      echo "Tags: ${release}, latest"
      echo "Use LocalStack: ${useLocalStack}"
      echo "========================================="

      sh """#!/bin/bash
        set +e  # Don't exit on error (for learning without AWS)

        if [ "${nodeEnv}" = "localhost" ]; then
          echo "Mac Jenkins: Using Local Docker Registry at localhost:5000..."

          REGISTRY_URI=localhost:5000/shipsmart-api

          # Tag images for local registry
          echo "Tagging images for local registry..."
          docker tag shipsmart-api:${release} \${REGISTRY_URI}:${release}
          docker tag shipsmart-api:latest \${REGISTRY_URI}:latest

          # Push to local registry
          echo "Pushing Docker images to local registry..."
          docker push \${REGISTRY_URI}:${release}
          docker push \${REGISTRY_URI}:latest

          echo "Local registry push complete!"
          echo "Images:"
          echo "  - \${REGISTRY_URI}:${release}"
          echo "  - \${REGISTRY_URI}:latest"
        elif [ "${useLocalStack}" = "true" ]; then
          echo "Containerized Jenkins: Using Local Docker Registry at registry:5000..."

          REGISTRY_URI=registry:5000/shipsmart-api

          # Tag images for local registry
          echo "Tagging images for local registry..."
          docker tag shipsmart-api:${release} \${REGISTRY_URI}:${release}
          docker tag shipsmart-api:latest \${REGISTRY_URI}:latest

          # Push to local registry
          echo "Pushing Docker images to local registry..."
          docker push \${REGISTRY_URI}:${release}
          docker push \${REGISTRY_URI}:latest

          echo "Local registry push complete!"
          echo "Images:"
          echo "  - \${REGISTRY_URI}:${release}"
          echo "  - \${REGISTRY_URI}:latest"
        else
          # Check if AWS credentials are available
          if aws sts get-caller-identity >/dev/null 2>&1; then
            echo "AWS credentials found, proceeding with ECR push..."

            # Login to ECR
            echo "Logging into ECR..."
            aws ecr get-login-password --region ${awsRegion} | docker login --username AWS --password-stdin ${awsAccountId}.dkr.ecr.${awsRegion}.amazonaws.com

            # Create ECR repository if it doesn't exist
            aws ecr describe-repositories --repository-names shipsmart-api --region ${awsRegion} >/dev/null 2>&1 || \
              aws ecr create-repository --repository-name shipsmart-api --region ${awsRegion}

            # Push images
            echo "Pushing Docker images to ECR..."
            docker push ${imageName}:${release}
            docker push ${imageName}:latest

            echo "ECR push complete!"
          else
            echo "AWS credentials not found or not configured"
            echo "Skipping ECR push (this is expected for local development)"
            echo "To enable ECR push:"
            echo "  1. Set USE_LOCALSTACK=true for local testing, OR"
            echo "  2. Configure AWS credentials in Jenkins"
            echo "  3. Create ECR repository: shipsmart-api"
          echo "  3. Grant Jenkins IAM role ECR push permissions"
        fi
      """

      echo "ECR stage complete!"
    }

    // =============================================================================
    // STAGE 8: DEPLOY (OPTIONAL)
    // =============================================================================
    stage('Deploy') {
      if (deployEnabled == 'true') {
        echo "========================================="
        echo "Stage 8: Deploy to ${nodeEnv}"
        echo "========================================="

        sh """#!/bin/bash
          set +e  # Don't exit on error

          # Check if deployment script exists
          if [ -f scripts/deploy.sh ]; then
            echo "Running deployment script..."
            bash scripts/deploy.sh ${nodeEnv} ${release}
          else
            echo "Deployment script not found"
            echo "Create scripts/deploy.sh for automated deployment"
            echo ""
            echo "Example deployment strategies:"
            echo "  - SSH to EC2 and pull latest Docker image"
            echo "  - Update ECS task definition with new image"
            echo "  - Kubernetes rolling update"
            echo "  - Blue-green deployment with AWS CodeDeploy"
          fi
        """

        echo "Deploy stage complete!"
      } else {
        echo "Deployment disabled (DEPLOY_ENABLED=false)"
        echo "To enable deployment, set DEPLOY_ENABLED=true in Jenkins parameters"
      }
    }

    // =============================================================================
    // SUCCESS NOTIFICATION
    // =============================================================================
    if (notification == 'true') {
      echo "========================================="
      echo "Build Successful!"
      echo "========================================="
      echo "Job: ${jobName}"
      echo "Branch: ${release}"
      echo "Environment: ${nodeEnv}"
      echo "Image: ${imageName}:${release}"
      echo "========================================="

      // Slack notification (optional)
      // slackSend(
      //   color: 'good',
      //   message: "Build successful: ${jobName} - ${release}\nEnvironment: ${nodeEnv}"
      // )
    }

  } catch (Exception e) {
    // =============================================================================
    // ERROR HANDLING
    // =============================================================================
    echo "========================================="
    echo "Build Failed!"
    echo "========================================="
    echo "Error: ${e.message}"
    echo "========================================="

    currentBuild.result = 'FAILURE'
    slackError = 1

    // Send failure notification
    if (notification == 'true') {
      // Slack notification (optional)
      // slackSend(
      //   color: 'danger',
      //   message: "Build failed: ${jobName} - ${release}\nEnvironment: ${nodeEnv}\nError: ${e.message}"
      // )

      echo "Failure notification sent"
    }

    // Re-throw exception to mark build as failed
    throw e

  } finally {
    // =============================================================================
    // CLEANUP
    // =============================================================================
    echo "========================================="
    echo "Cleanup"
    echo "========================================="

    // Clean up Docker images to save space (optional)
    sh """#!/bin/bash
      # Remove dangling images
      docker image prune -f || true

      echo "Cleanup complete!"
    """
  }
}
