# =============================================================================
# ShipSmart AI API — Local Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in your local values:
#   cp .env.example .env
#
# HOW THIS WORKS:
#   - .env is loaded by packages/env/index.js via dotenv at startup
#   - These env vars override values in config/config.development.json
#   - .env is gitignored — never commit it
#   - In staging/production, ECS injects these from AWS Secrets Manager
#     (no .env file needed on the server)
#
# NAMING CONVENTION:
#   Nested config keys use __ (double underscore) as separator
#   jwt:secret      → JWT__SECRET
#   encryption:key  → ENCRYPTION__KEY
#   postgres:password → POSTGRES__PASSWORD
# =============================================================================

# --- JWT ---
# Used for signing/verifying authentication tokens
# Must be at least 32 characters
# Generate: openssl rand -base64 48
JWT__SECRET=

# --- Encryption ---
# Used for AES-256 encryption of carrier API credentials
# Must be exactly 32 characters (hex: openssl rand -hex 16)
ENCRYPTION__KEY=

# --- PostgreSQL ---
# Password for the local PostgreSQL database
# Default local password is usually "postgres"
POSTGRES__PASSWORD=

# --- Redis ---
# Password for the local Redis instance
# Set in docker-compose.yml as REDIS_PASSWORD (default: "redis")
BULL__DEFAULT_REDIS__PASSWORD=
