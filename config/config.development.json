{
  "environment": "development",
  "service": {
    "port": 3001
  },
  "postgres": {
    "username": "postgres",
    "database": "shipsmart_db",
    "host": "localhost",
    "port": 5432,
    "dialect": "postgres",
    "pool": {
      "max": 5,
      "min": 0,
      "acquire": 60000,
      "idle": 10000
    }
  },
  "aws": {
    "region": "us-east-1",
    "access_key": "test",
    "secret_access_key": "test",
    "s3": {
      "bucket_prefix": "shipsmart",
      "endpoint": "http://localhost:9090"
    }
  },
  "bull": {
    "worker": {
      "queue_name": "shipsmart-worker"
    },
    "default_redis": {
      "port": 6379,
      "host": "127.0.0.1"
    },
    "advanced_settings": {
      "lock_duration": 600000,
      "lock_renew_time": 300000,
      "stalled_interval": 600000
    }
  },
  "bull-arena": {
    "ui_port": 3050,
    "default_redis": {
      "port": 6379,
      "host": "127.0.0.1"
    },
    "queues": [
      {
        "hostId": "localhost",
        "name": "CHECK_CREATION"
      },
      {
        "hostId": "localhost",
        "name": "RATE_FETCH"
      }
    ]
  },
  "carriers": {
    "fedex": {
      "api_url": "https://apis-sandbox.fedex.com",
      "timeout": 15000,
      "rate_cache_ttl": 300
    },
    "ups": {
      "api_url": "https://wwwcie.ups.com",
      "timeout": 15000,
      "rate_cache_ttl": 300
    },
    "usps": {
      "api_url": "https://apis-tem.usps.com",
      "timeout": 15000,
      "rate_cache_ttl": 300
    },
    "dhl": {
      "api_url": "https://api-sandbox.dhl.com",
      "timeout": 15000,
      "rate_cache_ttl": 300
    }
  },
  "rate_shopping": {
    "max_carriers": 4,
    "parallel_requests": true,
    "cache_enabled": true,
    "default_cache_ttl": 300
  }
}
