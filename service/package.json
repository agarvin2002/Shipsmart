{
  "name": "@shipsmart/service",
  "version": "1.0.0",
  "description": "ShipSmart Node Service",
  "scripts": {
    "start": "node bin/server",
    "dev": "npx nodemon bin/server",
    "worker": "node bin/worker",
    "worker:dev": "npx nodemon bin/worker",
    "arena": "node bin/arena",
    "arena:dev": "npx nodemon bin/arena",
    "lint": "eslint",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "db:migrate:status": "npx sequelize-cli db:migrate:status",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all"
  },
  "dependencies": {
    "@hapi/joi": "15.0.3",
    "@shipsmart/constants": "1.0.0",
    "@shipsmart/env": "1.0.0",
    "@shipsmart/errors": "1.0.0",
    "@shipsmart/logger": "1.0.0",
    "aws-sdk": "^2.817.0",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.19.0",
    "bull": "^4.1.1",
    "bull-arena": "^3.20.1",
    "cls-hooked": "^4.2.2",
    "cookie-parser": "^1.4.5",
    "express": "^4.17.1",
    "express-rate-limit": "^7.1.5",
    "express-request-id": "^1.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.5.1",
    "redis": "2.8.0",
    "sequelize": "^5.8.9",
    "sprintf-js": "^1.1.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.7",
    "sequelize-cli": "^6.6.3"
  }
}
