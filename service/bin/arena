#!/usr/bin/env node

const Arena = require('bull-arena');
const Bull = require('bull');
const config = require('@shipsmart/env');

global.logger = require('@shipsmart/logger').application('arena');

const arenaConfig = config.get('bull-arena');
const redisConfig = arenaConfig.default_redis;

// Initialize Arena
const arena = Arena(
  {
    Bull,
    queues: arenaConfig.queues.map((queue) => ({
      name: queue.name,
      hostId: queue.hostId,
      type: 'bull',
      redis: {
        host: redisConfig.host,
        port: redisConfig.port,
        password: redisConfig.password || undefined
      }
    }))
  },
  {
    basePath: '/',
    disableListen: false,
    port: arenaConfig.ui_port
  }
);

arena.on('listening', () => {
  logger.info(`Bull Arena UI started on http://localhost:${arenaConfig.ui_port}`);
});

// Graceful shutdown
function gracefulShutdown(signal) {
  logger.info(`${signal} received. Closing Bull Arena server...`);
  process.exit(0);
}

process.on('SIGTERM', () => gracefulShutdown('SIGTERM'));
process.on('SIGINT', () => gracefulShutdown('SIGINT'));
